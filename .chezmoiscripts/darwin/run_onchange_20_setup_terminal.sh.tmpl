#!/bin/bash

# Install Oh My Zsh
if [ ! -f ~/.oh-my-zsh/oh-my-zsh.sh ]; then
  (echo "🛠️  Installing oh-my-zsh" && yes | sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)")
fi

# Configure defaults for iterm2
if [ -d "/Applications/iTerm.app" ]; then
  echo "🛠️  Configuring iterm2 preferences"

  # Specify the preferences directory
  defaults write com.googlecode.iterm2.plist PrefsCustomFolder -string "$HOME/.config/iterm2"

  # Tell iTerm2 to use the custom preferences in the directory
  defaults write com.googlecode.iterm2.plist LoadPrefsFromCustomFolder -bool true
fi

osascript -e 'tell application "Terminal" to set font of settings set "Basic" to "{{ .apps.terminal.font.name }}"' &
osascript -e 'tell application "Terminal" to set font size of settings set "Basic" to {{ .apps.terminal.font.size }}' &

echo "✅  Done. Terminal is fully functional now."
